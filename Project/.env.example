# Copy these into your shell config (~/.zshrc) and fill in your real values.
# NEVER commit your real key — this file is just a template.
#
#   export ARK_API_KEY="ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
#   export DOUBAO_MODEL_ID="doubao-1-5-lite-32k-250115"
#   export DOUBAO_VISION_MODEL_ID="doubao-1-5-vision-pro-32k-250115"
#
# Then run:  source ~/.zshrc

ARK_API_KEY=
DOUBAO_MODEL_ID=doubao-1-5-lite-32k-250115
# Vision model — enables the "upload a photo" feature. Leave blank to disable.
DOUBAO_VISION_MODEL_ID=
